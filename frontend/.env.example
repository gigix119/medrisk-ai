# Copy to .env.local for local development. Every value here is a safe placeholder -
# none of this is committed with real values, and none of it should be treated as secret
# (it all ends up in the client-side JS bundle).

# --- Brand (temporary working name, fully configurable) ---
VITE_APP_NAME="MedRisk AI"
VITE_APP_SHORT_NAME="MedRisk"
VITE_APP_TAGLINE="Transparent AI research for histopathology image analysis."
VITE_PUBLIC_SITE_URL=http://localhost:5173
VITE_GITHUB_URL=
VITE_CONTACT_EMAIL=

# --- Backend ---
# Must match a CORS_ORIGINS entry in the backend's .env (see ../.env.example).
VITE_API_BASE_URL=http://localhost:8000

# --- Locale / feature flags ---
VITE_DEFAULT_LOCALE=en
VITE_ENABLE_DEMO_MODE=false
VITE_ENABLE_MOCK_API=false
