# Copy this file to ".env" and fill in real local values.
# Never commit the real ".env" file.

# --- Application ---
APP_NAME=MedRisk AI
APP_VERSION=0.1.0
# development | test | production
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

# --- Database (used directly by the application) ---
# Local native PostgreSQL install, default instance on localhost:5432
DATABASE_URL=postgresql+asyncpg://medrisk:medrisk@localhost:5432/medrisk
TEST_DATABASE_URL=postgresql+asyncpg://medrisk:medrisk@localhost:5432/medrisk_test

# --- PostgreSQL container/service settings (used by docker compose + init scripts) ---
POSTGRES_DB=medrisk
POSTGRES_TEST_DB=medrisk_test
POSTGRES_USER=medrisk
POSTGRES_PASSWORD=medrisk
POSTGRES_PORT=5432

# --- JWT ---
# Generate a real secret locally, e.g.: python -c "import secrets; print(secrets.token_urlsafe(64))"
# There is NO safe default for this value outside of the test environment.
JWT_SECRET_KEY=changeme-generate-a-real-secret-for-local-dev
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ISSUER=medrisk-ai
JWT_AUDIENCE=medrisk-ai-clients

# --- CORS / hosts ---
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:5173
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Logging ---
LOG_LEVEL=INFO

# --- Histopathology model deployment (Phase 3) ---
# No real PCam-trained model exists yet (see docs/model-deployment.md) - the only bundle
# in this repo is the synthetic smoke-test bundle from Phase 2, which has NO medical
# meaning. Leave MODEL_REQUIRED=false for local development without a model, or point
# MODEL_BUNDLE_PATH at it to exercise the full inference pipeline locally:
#   MODEL_BUNDLE_PATH=artifacts/model_registry/smoke-baseline-cnn/0.0.1-smoke
#   ALLOW_SYNTHETIC_MODEL=true   (required for that bundle to load outside ENVIRONMENT=test)
MODEL_REQUIRED=false
MODEL_BUNDLE_PATH=
# auto | cpu | cuda | mps
MODEL_DEVICE=auto
MODEL_WARMUP_ENABLED=true
MODEL_STRICT_VERSION_CHECK=true
ALLOW_SYNTHETIC_MODEL=false

# --- Inference request handling ---
INFERENCE_TIMEOUT_SECONDS=20
INFERENCE_QUEUE_TIMEOUT_SECONDS=5
INFERENCE_MAX_CONCURRENCY=1

# --- Upload / image limits ---
MAX_UPLOAD_BYTES=5242880
MAX_IMAGE_WIDTH=4096
MAX_IMAGE_HEIGHT=4096
MAX_IMAGE_PIXELS=16777216
MIN_IMAGE_WIDTH=32
MIN_IMAGE_HEIGHT=32
STRICT_MODEL_INPUT_SHAPE=true

# --- Grad-CAM explanation ---
GRADCAM_ENABLED=true
GRADCAM_MAX_OUTPUT_BYTES=500000

# --- Dataset registry (Phase 6) ---
DATASETS_ROOT=artifacts/datasets

# --- Local-dev-only account seeding (Phase 6) ---
# Leave both empty to skip seeding entirely. Settings hard-fails startup if either is set
# while ENVIRONMENT=production - never set these outside local development.
DEV_SEED_USER_EMAIL=
DEV_SEED_USER_PASSWORD=

# --- Rate limiting (Phase 8) ---
# In-memory, per-process sliding-window limits - see app/core/rate_limit.py and
# docs/SECURITY_AUDIT.md for the "instance-local, not distributed" caveat.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_REGISTER_PER_MINUTE=5
RATE_LIMIT_INFERENCE_PER_MINUTE=30
RATE_LIMIT_RESEARCH_WRITE_PER_MINUTE=10

# --- Build provenance (Phase 8) ---
# Set automatically by the Dockerfiles' GIT_COMMIT_SHA build ARG; leave empty for plain
# local `uvicorn` runs (GET /version reports null rather than a fabricated value).
GIT_COMMIT_SHA=
